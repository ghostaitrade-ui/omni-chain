# ── EXISTING KEYS ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_key_here
ALPHA_VANTAGE_KEY=your_key_here
FRED_API_KEY=your_key_here
ALPACA_BASE_URL=your_key_here

# ── ROUND 1: FINANCIAL NEWS & SENTIMENT ───────────────────────
# Finnhub — finnhub.io → Get Free API Key
FINNHUB_KEY=your_key_here

# QuiverQuant — quiverquant.com → Sign up free → Account → API
QUIVERQUANT_KEY=your_key_here

# NewsAPI — newsapi.org → Get API Key
NEWSAPI_KEY=your_key_here

# Polygon.io — polygon.io → free tier
POLYGON_KEY=your_key_here

# ── ROUND 2: REDDIT SOCIAL SENTIMENT ──────────────────────────
# reddit.com/prefs/apps → Create App → choose "script"
# App name: omni-chain (or anything), redirect: http://localhost:8080
REDDIT_CLIENT_ID=your_key_here
REDDIT_CLIENT_SECRET=your_key_here
REDDIT_USER_AGENT=your_key_here

# ── ROUND 3: GOOGLE ECOSYSTEM ─────────────────────────────────
# console.cloud.google.com → New Project → Enable APIs below
# YouTube Data API v3 — enable in Google Cloud Console
YOUTUBE_API_KEY=your_key_here
# Google Custom Search API + create a search engine at programmablesearchengine.google.com
GOOGLE_SEARCH_API_KEY=your_key_here
GOOGLE_SEARCH_ENGINE_ID=your_key_here

# ── ROUND 4: ECONOMIC & CONSUMER DATA (no keys needed) ────────
# SEC EDGAR  — https://efts.sec.gov/LATEST/search-index (no key)
# World Bank — https://api.worldbank.org/v2 (no key)
# Census     — api.census.gov → request key (free, instant email)
CENSUS_API_KEY=your_key_here
